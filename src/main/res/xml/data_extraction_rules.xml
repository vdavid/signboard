<?xml version="1.0" encoding="utf-8"?>
<!-- The app stores only the displayed text and its history, all recreatable by the user, so
     nothing here is worth transferring. This mirrors android:allowBackup="false", which
     covers Android 11 and below; these rules cover 12 and above. -->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="root" />
    <exclude domain="sharedpref" />
  </cloud-backup>
  <device-transfer>
    <exclude domain="root" />
    <exclude domain="sharedpref" />
  </device-transfer>
</data-extraction-rules>
