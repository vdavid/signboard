<?xml version="1.0" encoding="utf-8"?>
<!-- Android 11 and below. Pairs with res/xml/data_extraction_rules.xml, which covers 12+.
     Nothing is backed up: the app stores only the displayed text and its history. -->
<full-backup-content>
  <exclude domain="root" path="." />
  <exclude domain="sharedpref" path="." />
</full-backup-content>
